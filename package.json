{
  "name": "flatten-string",
  "version": "0.2.0",
  "type": "module",
  "funding": "https://github.com/sponsors/Jaid",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jaid/flatten-string.git"
  },
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "import": "./dist/main.js",
      "default": "./dist/main.js"
    }
  },
  "imports": {
    "#src/*": "./src/*",
    "#root/*": "./*"
  },
  "scripts": {
    "build": "tsdown",
    "build:watch": "tsdown --watch",
    "test": "bun test --max-concurrency 1 ./test"
  },
  "devDependencies": {
    "bun-types": "^1.3.14",
    "eslint": "^10.4.0",
    "eslint-config-jaid": "^26.0.0",
    "fs-extra": "^11.3.2",
    "terser": "^5.46.2",
    "tsconfig-jaid-bun": "^15.2.0",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3"
  },
  "files": [
    "dist"
  ],
  "types": "./dist/main.d.ts"
}